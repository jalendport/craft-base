{# Shared macros for jalendport plugin settings pages.

   Usage:
     {% import 'jalendport-base/_macros' as base %}
     {{ forms.lightswitchField({
         …,
         warning: base.configWarning('enabled', 'altcha'),
     }) }}
#}

{# Returns a warning string when the setting is overridden in config/<file>.php, else empty.

   The message is translated against the calling plugin's own category (`file` is
   the plugin handle), so each plugin ships the source string in its
   translations/en/<handle>.php. #}
{% macro configWarning(setting, file) -%}
    {%- set config = craft.app.config.getConfigFromFile(file) -%}
    {%- if config[setting] is defined -%}
        {{- 'This setting is being overridden by the {setting} setting in your {file} config file.'|t(file, {
            setting: '<code>' ~ setting ~ '</code>',
            file: '<code>config/' ~ file ~ '.php</code>',
        })|raw -}}
    {%- endif -%}
{%- endmacro %}
