{
  "name": "jalendport/craft-base",
  "description": "Shared foundation for jalendport Craft CMS plugins",
  "type": "library",
  "license": "mit",
  "authors": [
    {
      "name": "Jalen Davenport",
      "homepage": "https://jalendport.com"
    }
  ],
  "support": {
    "email": "hello@jalendport.com",
    "issues": "https://github.com/jalendport/craft-base/issues?state=open",
    "source": "https://github.com/jalendport/craft-base",
    "docs": "https://github.com/jalendport/craft-base/blob/master/README.md"
  },
  "require": {
    "php": "^8.2",
    "craftcms/cms": "^5.0.0"
  },
  "require-dev": {
    "craftcms/ecs": "dev-main",
    "craftcms/phpstan": "dev-main",
    "craftcms/rector": "dev-main",
    "pestphp/pest": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "jalendport\\base\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "jalendport\\base\\tests\\": "tests/"
    }
  },
  "scripts": {
    "check-cs": "ecs check --ansi",
    "fix-cs": "ecs check --ansi --fix",
    "phpstan": "phpstan --memory-limit=1G",
    "test": "pest"
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.2"
    },
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "yiisoft/yii2-composer": true,
      "craftcms/plugin-installer": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
